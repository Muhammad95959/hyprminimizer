{
  "specialWorkspace": "minimized",
  "trayModule": "systemtray",
  "restoreLauncher": "rofi",
  "restoreLauncherArgs": "-dmenu -p \"Restore window:\"",
  "maxMinimizedWindows": 50,
  "excludeWindowClasses": [
    "waybar",
    "dunst",
    "swaylock",
    "hyprpicker",
    "wlogout"
  ],
  "useDBusTray": true,
  "dbusServiceName": "org.hyprminimizer",
  "enableNotifications": true,
  "notificationCommand": "notify-send",
  "restoreToCurrentWorkspace": true,
  "iconPack": {
    "firefox": "firefox",
    "Alacritty": "alacritty",
    "code-oss": "code-oss",
    "Code": "code",
    "google-chrome": "google-chrome",
    "chromium-browser": "chromium-browser",
    "org.wezfurlong.wezterm": "wezterm",
    "thunar": "thunar",
    "nemo": "nemo",
    "org.gnome.Nautilus": "nautilus",
    "gimp": "gimp-2.10",
    "vlc": "vlc",
    "mpv": "mpv",
    "obsidian": "obsidian",
    "Slack": "slack",
    "discord": "discord",
    "TelegramDesktop": "telegram",
    "org.telegram.desktop": "telegram"
  }
}
